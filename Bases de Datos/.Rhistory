library(patchwork)
# Extraer y limpiar datos
uk_data <- extract_grid(type = "tsibble", columns = "ND", aggregate = "hourly") %>%
fill_gaps()
# 1. Modelo solo para el DÍA (24h)
fit_day <- uk_data %>% model(m = TSLM(ND ~ fourier(period = "day", K = 10)))
# 2. Modelo solo para la SEMANA (168h)
fit_week <- uk_data %>% model(m = TSLM(ND ~ fourier(period = "week", K = 8)))
# 3. Modelo solo para el AÑO (8766h)
fit_year <- uk_data %>% model(m = TSLM(ND ~ fourier(period = "year", K = 5)))
comp_estacionales <- uk_data %>%
mutate(
Real = ND,
Componente_Dia = fitted(fit_day)$.fitted,
Componente_Semana = fitted(fit_week)$.fitted,
Componente_Año = fitted(fit_year)$.fitted
)
# Gráfico A: Componente Diaria (Zoom a 2 días)
p1 <- comp_estacionales %>%
filter(TIMESTAMP >= max(TIMESTAMP) - days(2)) %>%
ggplot(aes(x = TIMESTAMP)) +
geom_line(aes(y = Real), color = "gray80", size = 0.5) +
geom_line(aes(y = Componente_Dia), color = "firebrick", size = 1) +
labs(title = "Componente Diaria (Fourier 24h)", y = "MW") +
theme_minimal()
# Gráfico B: Componente Semanal (Zoom a 2 semanas)
p2 <- comp_estacionales %>%
filter(TIMESTAMP >= max(TIMESTAMP) - weeks(2)) %>%
ggplot(aes(x = TIMESTAMP)) +
geom_line(aes(y = Real), color = "gray80", size = 0.5) +
geom_line(aes(y = Componente_Semana), color = "royalblue", size = 1) +
labs(title = "Componente Semanal (Fourier 168h)", y = "MW") +
theme_minimal()
# Gráfico C: Componente Anual (Todo el histórico o 1 año)
p3 <- comp_estacionales %>%
filter(TIMESTAMP >= max(TIMESTAMP) - years(1)) %>%
ggplot(aes(x = TIMESTAMP)) +
geom_line(aes(y = Real), color = "gray80", size = 0.5) +
geom_line(aes(y = Componente_Año), color = "forestgreen", size = 1) +
labs(title = "Componente Anual (Fourier 8766h)", y = "MW") +
theme_minimal()
# Mostrar los tres gráficos
p1 / p2 / p3
