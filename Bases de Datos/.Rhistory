uk_tsbl <- extract_grid(type = "tsibble",
columns = "ND",
aggregate = "hourly")
uk_clean <- uk_tsbl %>%
mutate(TIMESTAMP = as_datetime(TIMESTAMP)) %>%
fill_gaps() # Importante para que Fourier no falle por huecos temporales
?TSLM
uk_clean
fit <- uk_clean %>%
model(
fourier_model = TSLM(ND ~ fourier(period = "day", K = 10) +
fourier(period = "week", K = 5) +
fourier(period = "year", K = 3))
)
augment(fit) %>%
filter(TIMESTAMP >= max(TIMESTAMP) - days(14)) %>%
ggplot(aes(x = TIMESTAMP)) +
geom_line(aes(y = ND, colour = "Demanda Real"), alpha = 0.3) +
geom_line(aes(y = .fitted, colour = "Modelo Fourier"), size = 1) +
scale_color_manual(values = c("Demanda Real" = "black", "Modelo Fourier" = "red")) +
labs(title = "Componentes Estacionales de la Demanda (Reino Unido)",
subtitle = "Ajuste mediante series de Fourier (Diario, Semanal y Anual)",
y = "Megawatts", x = "Fecha/Hora") +
theme_minimal()
