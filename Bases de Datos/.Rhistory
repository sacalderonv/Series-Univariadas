library(energy)
calcular_dacf_interna <- function(serie, max_lag = 20) {
sapply(1:max_lag, function(k) {
n_k <- length(serie)
# Recorte directo para alineación perfecta t vs t-k
x_t <- serie[(k + 1):n_k]
x_tk <- serie[1:(n_k - k)]
return(dcor(x_t, x_tk))
})
}
# 3. Comparación visual
lags <- 1:24
d_acf_vals <- calcular_dacf_interna(xtsimul, max_lag = 24)
abline(h = c(0.06, -0.06), lty = 2, col = "blue") # Líneas de significancia aprox.
library(energy)
calcular_dacf_interna <- function(serie, max_lag = 20) {
sapply(1:max_lag, function(k) {
n_k <- length(serie)
# Recorte directo para alineación perfecta t vs t-k
x_t <- serie[(k + 1):n_k]
x_tk <- serie[1:(n_k - k)]
return(dcor(x_t, x_tk))
})
}
# 3. Comparación visual
lags <- 1:24
d_acf_vals <- calcular_dacf_interna(xtsimul, max_lag = 24)
plot(lags, d_acf_vals, type = "h", main = "dACF (Distancia - Total)", col = "darkgreen", ylim = c(0, 1))
abline(h = c(0.06, -0.06), lty = 2, col = "blue") # Líneas de significancia aprox.
