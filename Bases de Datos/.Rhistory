uk_tsbl <- extract_grid(type = "tsibble",
columns = "ND",
aggregate = "hourly")
uk_clean <- uk_tsbl %>%
mutate(TIMESTAMP = as_datetime(TIMESTAMP)) %>%
fill_gaps() # Importante para que Fourier no falle por huecos temporales
fit <- uk_clean %>%
model(
fourier_model = TSLM(ND ~ fourier(period = "day", K = 10) +
fourier(period = "week", K = 5) +
fourier(period = "year", K = 3))
)
augment(fit) %>%
filter(TIMESTAMP >= max(TIMESTAMP) - days(14)) %>%
ggplot(aes(x = TIMESTAMP)) +
geom_line(aes(y = ND, colour = "Demanda Real"), alpha = 0.3) +
geom_line(aes(y = .fitted, colour = "Modelo Fourier"), size = 1) +
scale_color_manual(values = c("Demanda Real" = "black", "Modelo Fourier" = "red")) +
labs(title = "Componentes Estacionales de la Demanda (Reino Unido)",
subtitle = "Ajuste mediante series de Fourier (Diario, Semanal y Anual)",
y = "Megawatts", x = "Fecha/Hora") +
theme_minimal()
library(patchwork)
# Extraer y limpiar datos
uk_data <- extract_grid(type = "tsibble", columns = "ND", aggregate = "hourly") %>%
fill_gaps()
# 1. Modelo solo para el DÍA (24h)
fit_day <- uk_data %>% model(m = TSLM(ND ~ fourier(period = "day", K = 10)))
# 2. Modelo solo para la SEMANA (168h)
fit_week <- uk_data %>% model(m = TSLM(ND ~ fourier(period = "week", K = 8)))
# 3. Modelo solo para el AÑO (8766h)
fit_year <- uk_data %>% model(m = TSLM(ND ~ fourier(period = "year", K = 5)))
comp_estacionales <- uk_data %>%
mutate(
Real = ND,
Componente_Dia = fitted(fit_day)$.fitted,
Componente_Semana = fitted(fit_week)$.fitted,
Componente_Año = fitted(fit_year)$.fitted
)
# Gráfico A: Componente Diaria (Zoom a 2 días)
p1 <- comp_estacionales %>%
filter(TIMESTAMP >= max(TIMESTAMP) - days(2)) %>%
ggplot(aes(x = TIMESTAMP)) +
geom_line(aes(y = Real), color = "gray80", size = 0.5) +
geom_line(aes(y = Componente_Dia), color = "firebrick", size = 1) +
labs(title = "Componente Diaria (Fourier 24h)", y = "MW") +
theme_minimal()
# Gráfico B: Componente Semanal (Zoom a 2 semanas)
p2 <- comp_estacionales %>%
filter(TIMESTAMP >= max(TIMESTAMP) - weeks(2)) %>%
ggplot(aes(x = TIMESTAMP)) +
geom_line(aes(y = Real), color = "gray80", size = 0.5) +
geom_line(aes(y = Componente_Semana), color = "royalblue", size = 1) +
labs(title = "Componente Semanal (Fourier 168h)", y = "MW") +
theme_minimal()
# Gráfico C: Componente Anual (Todo el histórico o 1 año)
p3 <- comp_estacionales %>%
filter(TIMESTAMP >= max(TIMESTAMP) - years(1)) %>%
ggplot(aes(x = TIMESTAMP)) +
geom_line(aes(y = Real), color = "gray80", size = 0.5) +
geom_line(aes(y = Componente_Año), color = "forestgreen", size = 1) +
labs(title = "Componente Anual (Fourier 8766h)", y = "MW") +
theme_minimal()
# Mostrar los tres gráficos
p1 / p2 / p3
library(mgcv)
library(lubridate)
uk_data <- extract_grid(type = "tsibble", columns = "ND", aggregate = "hourly") %>%
mutate(
hora = hour(TIMESTAMP),
dia_sem = wday(TIMESTAMP),
dia_año = yday(TIMESTAMP)
)
uk_clean <- uk_data %>%
filter(!is.na(ND), !is.na(hora), !is.na(dia_sem), !is.na(dia_año))
# 2. Re-ajustar el modelo con el dataset limpio
fit_gam <- gam(ND ~ s(hora, bs = "cc", k = 12) +
s(dia_sem, bs = "cc", k = 7) +
s(dia_año, bs = "cc", k = 20),
data = uk_clean)
preds <- predict(fit_gam, type = "terms")
intercepto <- as.numeric(coef(fit_gam)[1])
uk_results <- uk_clean %>%
mutate(
Efecto_Hora = preds[, "s(hora)"],
Efecto_Semana = preds[, "s(dia_sem)"],
Efecto_Año = preds[, "s(dia_año)"],
Tendencia_Global = attr(preds, "constant")
)
# Visualizar la suma de componentes vs Real (últimas 2 semanas)
uk_results %>%
filter(TIMESTAMP >= max(TIMESTAMP) - days(14)) %>%
mutate(Prediccion_Total = Efecto_Hora + Efecto_Semana + Efecto_Año + Tendencia_Global) %>%
ggplot(aes(x = TIMESTAMP)) +
geom_line(aes(y = ND, color = "Real"), alpha = 0.4) +
geom_line(aes(y = Prediccion_Total, color = "Suma de Componentes (GAM)"), size = 1) +
labs(title = "Reconstrucción de la Demanda usando GAM",
subtitle = "Suma de efectos: Hora + Día + Año + Media",
y = "Megawatts") +
scale_color_manual(values = c("Real" = "grey", "Suma de Componentes (GAM)" = "red")) +
theme_minimal()
uk_results1 <- uk_clean %>%
bind_cols(as.data.frame(preds)) %>%
rename(Comp_Hora = `s(hora)`,
Comp_Semana = `s(dia_sem)`,
Comp_Año = `s(dia_año)`) %>%
mutate(
Tendencia_Global = intercepto,
# Escalamos cada componente sumándole la media para que se solape con la serie real
Componente_Dia = Comp_Hora + Tendencia_Global,
Componente_Semana = Comp_Semana + Tendencia_Global,
Componente_Año = Comp_Año + Tendencia_Global
)
# Gráfico A: Componente Diaria (Zoom a 2 días)
p1 <- uk_results1 %>%
filter(TIMESTAMP >= max(TIMESTAMP) - days(2)) %>%
ggplot(aes(x = TIMESTAMP)) +
geom_line(aes(y = ND), color = "gray80", size = 0.5) +
geom_line(aes(y = Componente_Dia), color = "firebrick", size = 1) +
labs(title = "Componente Diaria (GAM Spline)", y = "MW") +
theme_minimal()
# Gráfico B: Componente Semanal (Zoom a 2 semanas)
p2 <- uk_results1 %>%
filter(TIMESTAMP >= max(TIMESTAMP) - weeks(2)) %>%
ggplot(aes(x = TIMESTAMP)) +
geom_line(aes(y = ND), color = "gray80", size = 0.5) +
geom_line(aes(y = Componente_Semana), color = "royalblue", size = 1) +
labs(title = "Componente Semanal (GAM Spline)", y = "MW") +
theme_minimal()
# Gráfico C: Componente Anual (1 año)
p3 <- uk_results1 %>%
filter(TIMESTAMP >= max(TIMESTAMP) - years(1)) %>%
ggplot(aes(x = TIMESTAMP)) +
geom_line(aes(y = ND), color = "gray80", size = 0.5) +
geom_line(aes(y = Componente_Año), color = "forestgreen", size = 1) +
labs(title = "Componente Anual (GAM Spline)", y = "MW") +
theme_minimal()
p1 / p2 / p3
# 1. Aseguramos que 'mes' sea un factor en el dataset
uk_clean <- uk_clean %>%
mutate(mes = month(TIMESTAMP, label = TRUE))
# 2. Ajustamos el modelo (Mes como efecto fijo/factor)
fit_gam_mes <- gam(ND ~ s(hora, bs = "cc", k = 12) +
s(dia_sem, bs = "cc", k = 7) +
mes,
data = uk_clean)
# 3. Extraemos los términos y el intercepto
preds_mes <- as.data.frame(predict(fit_gam_mes, type = "terms"))
intercepto <- as.numeric(coef(fit_gam_mes)[1])
# 4. Unimos usando nombres limpios
# predict() devuelve una columna llamada 'mes'. La renombramos a 'Efecto_Mes'
uk_mes_results <- uk_clean %>%
bind_cols(preds_mes %>% rename(Efecto_Mes = mes)) %>%
mutate(Componente_Mes = Efecto_Mes + intercepto)
# 1. Aseguramos que 'mes' sea un factor en el dataset
uk_clean <- uk_clean %>%
mutate(mes = month(TIMESTAMP, label = TRUE))
# 2. Ajustamos el modelo (Mes como efecto fijo/factor)
fit_gam_mes <- gam(ND ~ s(hora, bs = "cc", k = 12) +
s(dia_sem, bs = "cc", k = 7) +
mes,
data = uk_clean)
# 3. Extraemos los términos y el intercepto
preds_mes <- as.data.frame(predict(fit_gam_mes, type = "terms"))
intercepto <- as.numeric(coef(fit_gam_mes)[1])
# 4. Unimos usando nombres limpios
# predict() devuelve una columna llamada 'mes'. La renombramos a 'Efecto_Mes'
uk_mes_results <- uk_clean %>%
bind_cols(preds_mes %>% rename(Efecto_Mes = mes)) %>%
mutate(Componente_Mes = Efecto_Mes + intercepto)
uk_results %>%
filter(hora %in% c(15, 16))
# Filtramos dos horas consecutivas para ver el "puente"
intervalo_3_4 <- uk_results %>%
filter(hora %in% c(15, 16))
ggplot(intervalo_3_4, aes(x = hora, y = ND)) +
# 1. La nube de puntos real (miles de días superpuestos)
geom_jitter(alpha = 0.05, color = "royalblue", width = 0.1) +
# 2. La línea del GAM (El Spline que conecta los knots)
# Usamos stat_summary para ver el promedio real vs la curva suave
stat_summary(fun = mean, geom = "line", aes(group = 1), color = "red", size = 1.5) +
stat_summary(fun = mean, geom = "point", color = "red", size = 3) +
labs(title = "Intervalo Crítico: 15:00 a 16:00",
subtitle = "El modelo estima la curva roja basándose en la masa de puntos azules de miles de días",
x = "Hora (Knots potenciales)", y = "Demanda (MW)") +
theme_minimal()
